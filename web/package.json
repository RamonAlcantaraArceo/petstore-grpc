{
  "name": "petstore-grpc-web",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-side gRPC-Web client for petstore-grpc Health service.",
  "scripts": {
    "gen": "bash ../scripts/gen_grpc_web.sh",
    "build": "esbuild demo/main.ts --bundle --outfile=demo/main.js --format=iife --sourcemap",
    "serve": "npx --yes http-server demo -p 8081 -c-1"
  },
  "dependencies": {
    "google-protobuf": "^4.0.2"
  },
  "devDependencies": {
    "@protocolbuffers/protoc-gen-js": "^4.0.2",
    "@types/google-protobuf": "^3.15.12",
    "esbuild": "^0.24.0",
    "grpc-web": "^2.0.2",
    "typescript": "^5.4.0"
  }
}
